# Copy this file to `.env` and fill in your real key.
# DeepSeek: https://platform.deepseek.com/

# Required for DeepSeek (OpenAI-compatible client)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Optional: base URL (default works for official API)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Alibaba DashScope (百炼) — text-embedding-v2 via LangChain DashScopeEmbeddings
# https://help.aliyun.com/zh/model-studio/
DASHSCOPE_API_KEY=your-dashscope-api-key
